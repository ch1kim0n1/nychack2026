# CivicLens backend — environment configuration
# -----------------------------------------------------------------------
# LOCAL DEV: copy this file to backend/.env and fill in your OPENAI_API_KEY.
#   cp backend/.env.example backend/.env   (or run `npm run setup` from root)
#
# PRODUCTION (Railway): set these in the Railway "Variables" tab instead.
#   DATABASE_URL is auto-injected by Railway when you link the Postgres service.
# -----------------------------------------------------------------------
# Do NOT commit real secrets.

# ── Database ─────────────────────────────────────────────────────────────
# LOCAL: docker-compose Postgres started by `npm run dev` / `npm run db:up`.
# PRODUCTION: Railway injects this automatically — replace the value below.
DATABASE_URL="postgresql://civiclens:civiclens@localhost:5433/civiclens?schema=public"

# ── OpenAI ───────────────────────────────────────────────────────────────
# Required for live routes (classify / risk analyze / draft).
# Demo and diff routes work WITHOUT this key (app boots key-less).
OPENAI_API_KEY="replace-with-your-openai-api-key"

# Optional. Defaults to gpt-4o-mini. Set to gpt-4o for higher quality.
# OPENAI_MODEL="gpt-4o-mini"

# ── Server ───────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────
# LOCAL: frontend dev server.
FRONTEND_URL="http://localhost:3000"
# PRODUCTION: your Vercel URL — uncomment and replace.
# FRONTEND_URL="https://civiclens.vercel.app"

# ── Runtime ──────────────────────────────────────────────────────────────
# LOCAL: use development for hot-reload and verbose errors.
NODE_ENV=development
# PRODUCTION: set to production in Railway Variables tab.
# NODE_ENV=production

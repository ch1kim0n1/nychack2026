# CivicLens backend — environment configuration
# Copy to backend/.env for local dev, or set these in the Railway "Variables" tab.
# Do NOT commit real secrets.

# Postgres connection string. Must point at a database with the pgvector
# extension enabled (`CREATE EXTENSION IF NOT EXISTS vector;`).
# On Railway this is auto-injected when you link the Postgres service.
# Include the schema so Prisma targets the right one.
DATABASE_URL="postgresql://civiclens:civiclens@localhost:5432/civiclens?schema=public"

# OpenAI API key — required for live routes (classify / risk analyze / draft).
OPENAI_API_KEY="sk-your-key-here"

# Optional. Defaults to gpt-4o-mini if unset.
# Set to gpt-4o for higher-quality output (at higher cost/latency).
OPENAI_MODEL="gpt-4o-mini"

# Port the server binds to. Railway sets PORT automatically; defaults to 3001.
PORT=3001

# Allowed CORS origin for the frontend (Vercel URL in production).
FRONTEND_URL="http://localhost:3000"

# Runtime environment.
NODE_ENV=production

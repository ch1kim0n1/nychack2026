generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Business {
  id              String        @id @default(uuid())
  name            String?
  city            String
  county          String?
  state           String        @default("TX")
  industry_code   String
  activities      Json
  expansion_plans Json?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  risk_findings   RiskFinding[]
}

model RegulatorySource {
  id               String            @id @default(uuid())
  title            String
  agency           String
  jurisdiction     String
  source_url       String            @unique
  source_type      String
  last_checked_at  DateTime?
  source_text_hash String?
  chunks           RegulatoryChunk[]
  change_logs      SourceChangeLog[]
}

model RegulatoryChunk {
  id                String           @id @default(uuid())
  source_id         String
  source            RegulatorySource @relation(fields: [source_id], references: [id])
  text              String
  embedding         Unsupported("vector(1536)")?
  jurisdiction_tags String[]
  industry_tags     String[]
  activity_tags     String[]
}

model RagQueryLog {
  id                 String   @id @default(uuid())
  query_text         String
  retrieved_chunks   Int
  retrieved_chunk_ids String[] @default([])
  created_at         DateTime @default(now())
}

model SourceChangeLog {
  id             String           @id @default(uuid())
  source_id      String
  source         RegulatorySource @relation(fields: [source_id], references: [id])
  detected_at    DateTime         @default(now())
  old_hash       String?
  new_hash       String
  change_type    String
  diff_summary   String?
  added_chunks   Int              @default(0)
  removed_chunks Int              @default(0)
}

model SavedProfile {
  id           String   @id @default(uuid())
  client_id    String
  label        String
  profile_json Json
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model ContactLead {
  id         String   @id @default(uuid())
  name       String
  email      String
  locations  String?
  message    String?
  created_at DateTime @default(now())
}

model RiskFinding {
  id                 String   @id @default(uuid())
  business_id        String
  business           Business @relation(fields: [business_id], references: [id])
  risk_level         String
  affected_area      String
  explanation        String
  recommended_action String
  source_url         String
  // Regulatory intelligence
  prerequisites         String[] @default([])  // permits/steps that must be done first
  is_hidden_requirement Boolean? // easy-to-miss requirement from a different agency/jurisdiction
  response_path         String?  // monitor | contact_agency | update_docs | change_plan | seek_clarification
  // Stakeholder + cost + timing
  permit_fee         String?
  effective_date     String?
  agency_department  String?
  agency_phone       String?
  agency_url         String?
  // Trust & citation fields
  confidence_level   String?  // high | medium | low
  jurisdiction_level String?  // city | county | state | federal | agency
  // Phase 1 — impact dimensions
  money_risk         String?  // high | medium | low
  delay_risk         String?  // high | medium | low
  legal_severity     String?  // high | medium | low
  urgency            String?  // immediate | soon | ongoing
  impact_score       Int?     // 0-100 composite
  impact_label       String?  // "Could delay opening" etc.
  // Phase 1 — action playbook
  who_to_contact     String?
  what_to_ask        String?
  documents_needed   String[] @default([])
  next_steps         String[] @default([])
  created_at         DateTime @default(now())
  // Manual validation
  review_state    String    @default("auto_approved") // "pending" | "approved" | "rejected" | "auto_approved"
  reviewer_note   String?
  reviewed_at     DateTime?
}

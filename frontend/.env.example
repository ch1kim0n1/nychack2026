# Base URL of the CivicLens backend API.
#
# LOCAL DEV (default) — points at the local NestJS backend started by `npm run dev`.
# The frontend also falls back to http://localhost:3001 in code if this is unset,
# so local dev works even without a .env.local file at all.
NEXT_PUBLIC_API_URL=http://localhost:3001

# PRODUCTION (Vercel) — uncomment and set to your Railway backend URL.
# Set this in the Vercel project "Environment Variables" tab for Production/Preview.
# NEXT_PUBLIC_API_URL=https://civiclens-backend.up.railway.app
